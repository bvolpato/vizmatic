{
  "name": "vizmatic",
  "version": "0.1.32",
  "description": "Theme-aware visual primitives and a headless renderer for diagrams, figures, and presentation frames.",
  "type": "module",
  "license": "MIT",
  "author": "Bruno Volpato",
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://bvolpato.github.io/vizmatic/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bvolpato/vizmatic.git"
  },
  "bugs": {
    "url": "https://github.com/bvolpato/vizmatic/issues"
  },
  "keywords": [
    "visualization",
    "satori",
    "resvg",
    "react",
    "diagrams",
    "presentations",
    "theme-aware",
    "ai-agents",
    "structured-visuals"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "assets",
    "dist",
    "examples",
    "PROMPT.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "vizmatic": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --target node20 --clean --external react && tsup src/index.ts --format cjs --dts --target node20 --external react --define.import.meta.url undefined && tsup src/cli.ts --format esm --dts --target node20 --external react",
    "prepare": "pnpm build",
    "lint": "pnpm typecheck && pnpm workflows:check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "render:examples": "pnpm build && tsx scripts/render-examples.ts && pnpm site:build",
    "playground:build": "tsx scripts/build-playground.ts",
    "site:build": "tsx scripts/build-site.ts",
    "docs:check": "tsx scripts/check-docs.ts",
    "workflows:check": "github-actionlint .github/workflows/*.yml",
    "site:serve": "node scripts/serve-docs.mjs docs 4173",
    "sync:plugin-versions": "node scripts/sync-plugin-versions.mjs",
    "security:audit": "pnpm audit --audit-level low",
    "deps:check": "pnpm security:audit && npm pack --dry-run",
    "verify": "pnpm lint && pnpm test && pnpm render:examples && pnpm docs:check && pnpm deps:check",
    "prepublishOnly": "pnpm verify"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "gifenc": "^1.0.3",
    "parse-css-color": "0.2.1",
    "react": "^19.1.0",
    "satori": "^0.28.0",
    "tsx": "^4.23.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@resvg/resvg-wasm": "2.6.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "esbuild": "0.28.1",
    "github-actionlint": "1.7.12",
    "shiki": "^4.3.0",
    "sucrase": "3.35.1",
    "tsup": "^8.5.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
